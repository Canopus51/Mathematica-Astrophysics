\:503c\:7cbe\:5ea6\:4e0d\:591f\:5bfc\:81f4\:6298\:5c04\:7387\:6ca1\:6709\:5dee\
\:522b\:ff0c\:8fd9\:91cc\:8003\:8651\:624b\:52a8\:505a\:5c55\:5f00\:3002",
  FontColor->RGBColor[
   0.788235294117647, 0.21176470588235294`, 0.6588235294117647]],
 "\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["R", "TI"]], "\[LongEqual]", 
         SqrtBox[
          RowBox[{"1", "-", 
            FractionBox[
             StyleBox["X", "TI"], 
             RowBox[{"1", "-", 
               StyleBox["Y", "TI"]}]]}]], "\[TildeTilde]", "1", "-", 
         FractionBox[
          StyleBox["X", "TI"], 
          RowBox[{"2", "(", 
            RowBox[{"1", "-", 
              StyleBox["Y", "TI"]}], ")"}]], ",", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["L", "TI"]], "\[LongEqual]", 
         SqrtBox[
          RowBox[{"1", "-", 
            FractionBox[
             StyleBox["X", "TI"], 
             RowBox[{"1", "+", 
               StyleBox["Y", "TI"]}]]}]], "\[TildeTilde]", "1", "-", 
         FractionBox[
          StyleBox["X", "TI"], 
          RowBox[{"2", "(", 
            RowBox[{"1", "+", 
              StyleBox["Y", "TI"]}], ")"}]], ",", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["L", "TI"]], "-", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["R", "TI"]], "\[LongEqual]", 
         FractionBox[
          StyleBox["X", "TI"], 
          RowBox[{"2", "(", 
            RowBox[{"1", "-", 
              StyleBox["Y", "TI"]}], ")"}]], "-", 
         FractionBox[
          StyleBox["X", "TI"], 
          RowBox[{"2", "(", 
            RowBox[{"1", "+", 
              StyleBox["Y", "TI"]}], ")"}]], "\[TildeTilde]", 
         FractionBox[
          StyleBox["X", "TI"], "2"], 
         FractionBox[
          RowBox[{
            RowBox[{"(", 
              RowBox[{"1", "+", 
                StyleBox["Y", "TI"]}], ")"}], "-", 
            RowBox[{"(", 
              RowBox[{"1", "-", 
                StyleBox["Y", "TI"]}], ")"}]}], 
          RowBox[{"(", 
            RowBox[{"1", "-", 
              SuperscriptBox[
               StyleBox["Y", "TI"], "2"]}], ")"}]], "\[TildeTilde]", 
         StyleBox["X", "TI"], 
         StyleBox["Y", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "n_R = \\sqrt{1-\\frac{X}{1-Y}}\\approx1-\\frac{X}{2(1-Y)}, n_L = \
\\sqrt{1-\\frac{X}{1+Y}}\\approx1-\\frac{X}{2(1+Y)}, \
n_L-n_R=\\frac{X}{2(1-Y)}-\\frac{X}{2(1+Y)} \\approx \
\\frac{X}{2}\\frac{(1+Y)-(1-Y)}{(1-Y^2)}\\approx XY", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5e0e6552-fefd-3346-a0f3-7eba8fbb7090"]
}], "Text",
