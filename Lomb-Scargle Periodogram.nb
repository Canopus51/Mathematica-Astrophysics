Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "\:8ba1\:7b97\:8be5\:9891\:7387\:4e0b\:7684\:632f\:5e45", " ", "A"}], ",", 
    RowBox[{"B", " ", "\:548c", " ", "\[Tau]"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"omegaBest", "=", 
     RowBox[{"2", " ", "Pi", " ", "fBest"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"S", "=", 
     RowBox[{"Total", "[", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "omegaBest", " ", "times"}], "]"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"C2", "=", 
     RowBox[{"Total", "[", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "omegaBest", " ", "times"}], "]"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"tau", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "C2", "]"}], ">", 
        RowBox[{"10", "^", 
         RowBox[{"-", "10"}]}]}], ",", 
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{"S", "/", "C2"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "omegaBest"}], ")"}]}], ",", "0"}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"cosTerm", "=", 
     RowBox[{"Cos", "[", 
      RowBox[{"omegaBest", " ", 
       RowBox[{"(", 
        RowBox[{"times", "-", "tau"}], ")"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sinTerm", "=", 
     RowBox[{"Sin", "[", 
      RowBox[{"omegaBest", " ", 
       RowBox[{"(", 
        RowBox[{"times", "-", "tau"}], ")"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{"y", "*", "cosTerm"}], "]"}], "/", 
      RowBox[{"Total", "[", 
       RowBox[{"cosTerm", "^", "2"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"B", "=", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{"y", "*", "sinTerm"}], "]"}], "/", 
      RowBox[{"Total", "[", 
       RowBox[{"sinTerm", "^", "2"}], "]"}]}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{
   "(*", "\:5728\:76f8\:4f4d\:7f51\:683c\:4e0a\:8ba1\:7b97\:6a21\:578b\:503c",
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phaseGrid", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"0", ",", "1", ",", "200"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"modelLine", "=", 
     RowBox[{
      RowBox[{"A", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"omegaBest", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"phaseGrid", "*", "period"}], "-", "tau"}], ")"}]}], 
        "]"}]}], "+", 
      RowBox[{"B", " ", 
       RowBox[{"Sin", "[", 
        RowBox[{"omegaBest", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"phaseGrid", "*", "period"}], "-", "tau"}], ")"}]}], 
        "]"}]}]}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"A", "\:3001", 
