     "\:6240\:4ee5\:4f1a\:662fSin\:51fd\:6570\:5b58\:5728\:76f8\:4f4d\:504f\
\:79fb"}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", "\:6dfb\:52a0\:5230\:6298\:53e0\:56fe", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"foldPlot", ",", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
