}, Open  ]],

Cell[TextData[{
 "\:53ef\:4ee5\:770b\:51fa",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"tan", 
         RowBox[{"(", "\[Tau]\[CapitalOmega]", ")"}], "\[LongEqual]", "tan", 
         RowBox[{"(", 
           RowBox[{"2", "\[Tau]\[Omega]"}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            UnderoverscriptBox["\[Sum]", 
             RowBox[{
               StyleBox["i", "TI"], "\[LongEqual]", "1"}], 
             StyleBox["n", "TI"], LimitsPositioning -> True], "sin", 
            RowBox[{"(", 
              RowBox[{"2", "\[Omega]", 
                SubscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["i", "TI"]]}], ")"}]}], 
          RowBox[{
            UnderoverscriptBox["\[Sum]", 
             RowBox[{
               StyleBox["i", "TI"], "\[LongEqual]", "1"}], 
             StyleBox["n", "TI"], LimitsPositioning -> True], "cos", 
            RowBox[{"(", 
              RowBox[{"2", "\[Omega]", 
                SubscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["i", "TI"]]}], ")"}]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\tan(\\tau \\Omega) = \\tan(2 \\tau \\omega) = \\frac{\\sum_{i=1}^n \
\\sin(2\\omega t_i)}{\\sum_{i=1}^n \\cos(2\\omega t_i)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d28c0be4-599b-e140-b2a0-14cece50fd75"]
}], "Text",
 CellChangeTimes->{
  3.986803805758775*^9, {3.986803838699974*^9, 
   3.9868038507834663`*^9}},ExpressionUUID->"33c3d6cd-ce6d-6b43-a7d7-\
a2e20aee930b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "\:751f\:6210\:6a21\:62df\:6570\:636e"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nPoints", "=", "70"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tMax", "=", "100"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"times", "=", 
     RowBox[{"Sort", "[", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "tMax"}], "}"}], ",", "nPoints"}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"fTrue", "=", "0.3"}], ";"}], "                ", 
   RowBox[{"(*", 
    RowBox[{"\:771f\:5b9e\:9891\:7387", " ", 
     RowBox[{"day", "^", 
      RowBox[{"{", 
       RowBox[{"-", "1"}], "}"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"\[Omega]True", "=", 
     RowBox[{"2", " ", "\[Pi]", " ", "fTrue"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"signal", "=", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Omega]True", " ", "times"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"noise", "=", 
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"0", ",", "0.15"}], "]"}], ",", "nPoints"}], "]"}]}], ";"}], 
   " ", 
   RowBox[{
   "(*", "\:6ce8\:5165\:4fe1\:53f7\:5f3a\:5ea6\:7684\:8bef\:5dee", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"y", "=", 
     RowBox[{"signal", "+", "noise"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "\:53ef\:89c6\:5316", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"\[Omega]True", " ", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "100"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "LightBlue"}]}], "]"}], ",", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"times", ",", "y"}], "}"}], "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"Pink", ",", 
          RowBox[{"PointSize", "[", "0.015", "]"}]}], "]"}]}]}], "]"}], ",", 
     RowBox[{
     "PlotLabel", "->", 
      "\"\<\:4e2d\:5fc3\:5316\:540e\:7684\:6570\:636e\:4e0e\:771f\:5b9e\:6b63\
\:5f26\:6ce2\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<t [day]\>\"", ",", "\"\<y\>\""}], "}"}]}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.986804563105219*^9, 3.986804563105219*^9}, 
