Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "2.", " ", "\:5b9a\:4e49\:5355\:4e2a\:9891\:7387\:7684", " ", "LS", " ", 
    "\:529f\:7387"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Total", " ", "\:7528\:4e8e\:6c42\:548c"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"LombScargleSingle", "[", 
     RowBox[{"\[Omega]_", ",", "t_", ",", "vals_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "n", ",", "y", ",", "S", ",", "C2", ",", "\[Tau]", ",", "cosTerm", ",",
         "sinTerm", ",", "num", ",", "den", ",", "totalPower"}], "}"}], ",", 
      RowBox[{
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{"vals", "-", 
         RowBox[{"Mean", "[", "vals", "]"}]}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"\:5185\:90e8\:4e2d\:5fc3\:5316", "\:ff0c", 
         RowBox[{"\:5373\:7cfb\:6570C", "=", "0"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"\:6b63\:4ea4\:5316", " ", "\[Tau]"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"S", "=", 
        RowBox[{"Total", "[", 
         RowBox[{"Sin", "[", 
          RowBox[{"2", " ", "\[Omega]", " ", "t"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"C2", "=", 
        RowBox[{"Total", "[", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", "\[Omega]", " ", "t"}], "]"}], "]"}]}], ";", " ", 
       RowBox[{
       "(*", "\:4e3a\:4e86\:4e0e\:63a8\:5bfc\:4e2d\:7684\:7cfb\:6570C\:533a\
\:5206", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"\[Tau]", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "C2", "]"}], ">", 
           RowBox[{"10", "^", 
            RowBox[{"-", "10"}]}]}], 
          RowBox[{"(*", "\:9632\:6b62\:9664\:96f6", "*)"}], ",", 
          RowBox[{
           RowBox[{"ArcTan", "[", 
            RowBox[{"S", "/", "C2"}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"2", " ", "\[Omega]"}], ")"}]}], ",", "0"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", "\:57fa\:51fd\:6570", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"cosTerm", "=", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Omega]", " ", 
          RowBox[{"(", 
           RowBox[{"t", "-", "\[Tau]"}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sinTerm", "=", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Omega]", " ", 
          RowBox[{"(", 
           RowBox[{"t", "-", "\[Tau]"}], ")"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"\:7cfb\:6570", " ", "A"}], ",", 
         RowBox[{"B", " ", 
          RowBox[{"(", "\:5bf9\:89d2\:5316\:540e", ")"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"num", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"y", " ", "cosTerm"}], "]"}], "^", "2"}], "/", 
          RowBox[{"Total", "[", 
           RowBox[{"cosTerm", "^", "2"}], "]"}]}], "+", 
         RowBox[{
          RowBox[{
           RowBox[{"Total", "[", 
            RowBox[{"y", " ", "sinTerm"}], "]"}], "^", "2"}], "/", 
          RowBox[{"Total", "[", 
           RowBox[{"sinTerm", "^", "2"}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"totalPower", "=", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"y", "^", "2"}], "]"}], "/", "n"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
       "(*", "\:5185\:7f6e\:9ed8\:8ba4\:7684\:5f52\:4e00\:5316\:65b9\:5f0f", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"num", "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "totalPower"}], ")"}]}]}]}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.986804563105219*^9, 3.986804563105219*^9}, 
