Cell[BoxData[
 RowBox[{
  UnderoverscriptBox["\[Sum]", 
   RowBox[{"i", "=", "1"}], "n"], 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[CapitalOmega]", " ", 
        RowBox[{"t", "[", "i", "]"}]}], "]"}]}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[Tau]", " ", "\[CapitalOmega]"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"\[Tau]", " ", "\[CapitalOmega]"}], "]"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"\[CapitalOmega]", " ", 
       RowBox[{"t", "[", "i", "]"}]}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{{3.986801828470537*^9, 3.986801884621225*^9}, 
   3.986801940435835*^9, {3.986802091268322*^9, 3.986802144050186*^9}, 
   3.986802200807373*^9, 3.9868025521256504`*^9, {3.986802903460476*^9, 
   3.9868029288446827`*^9}, 3.9868030383521976`*^9, 3.9868035119889545`*^9, 
   3.986803679476553*^9, 3.986803796221845*^9, {3.986803975474132*^9, 
   3.986804008655319*^9}, 3.986810742311119*^9, 3.9868111962292743`*^9, 
   3.9868530065120983`*^9},
