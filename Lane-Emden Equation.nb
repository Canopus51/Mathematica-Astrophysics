Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"\:60f3\:753b\:7684", " ", "n", " ", "\:5217\:8868"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nList", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "2", ",", "3", ",", "4", ",", "5"}], 
      "}"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Epsilon]", "=", 
     RowBox[{"10", "^", 
      RowBox[{"-", "10"}]}]}], ";"}], " ", 
   RowBox[{"(*", "\:521d\:503c", "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"\:5b9a\:4e49\:4e00\:4e2a\:51fd\:6570", "\:ff1a", 
     RowBox[{"\:7ed9\:5b9a", " ", "n"}], "\:ff0c", 
     RowBox[{"\:8fd4\:56de", " ", "\[Omega]", 
      RowBox[{"(", "z", ")"}], " ", "\:7684\:6570\:503c\:89e3"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"solveLE", "[", "n_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"LEeq", ",", "ics", ",", "sol"}], "}"}], ",", 
       RowBox[{
        RowBox[{"LEeq", "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"\[Omega]", "''"}], "[", "z", "]"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"2", "/", "z"}], ")"}], " ", 
            RowBox[{
             RowBox[{"\[Omega]", "'"}], "[", "z", "]"}]}], "+", 
           RowBox[{
            RowBox[{"\[Omega]", "[", "z", "]"}], "^", "n"}]}], "==", "0"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"ics", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Omega]", "[", "\[Epsilon]", "]"}], "==", 
            RowBox[{"1", "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "/", "6"}], ")"}], " ", 
              RowBox[{"\[Epsilon]", "^", "2"}]}]}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"\[Omega]", "'"}], "[", "\[Epsilon]", "]"}], "==", 
            RowBox[{
             RowBox[{"-", 
              RowBox[{"(", 
               RowBox[{"1", "/", "3"}], ")"}]}], " ", "\[Epsilon]"}]}]}], 
          "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"sol", "=", 
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"LEeq", ",", "ics"}], "}"}], ",", "\[Omega]", ",", 
           RowBox[{"{", 
            RowBox[{"z", ",", "\[Epsilon]", ",", "10"}], "}"}], ",", 
           RowBox[{"MaxSteps", "->", "Infinity"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "sol"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"\:6c42\:6240\:6709", " ", "n", " ", "\:7684\:89e3"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solList", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"n", ",", 
         RowBox[{"solveLE", "[", "n", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "nList"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "\:7ed8\:56fe", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Omega]", "[", "z", "]"}], "/.", " ", 
         RowBox[{"solList", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "nList", "]"}]}], "}"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"z", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.5"}], ",", "1"}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Thick"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<z\>\"", ",", "\"\<\[Omega](z)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"LineLegend", "[", 
         RowBox[{"nList", ",", 
          RowBox[{"LegendLabel", "->", "\"\<n\>\""}]}], "]"}], ",", "Right"}],
        "]"}]}]}], "]"}], "\n"}]}]], "Input",
